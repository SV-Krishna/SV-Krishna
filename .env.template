# Core mode
NODE_ENV=development
LOG_LEVEL=info
ENABLE_WEB_UI=true
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=8080
ENABLE_EMBEDDING_POC=false
EMBEDDING_MODEL=all-minilm:33m
EMBEDDING_STORE_PATH=/opt/svkrishna/rag/embeddings.json
EMBEDDING_TOP_K=3

# Runtime mode
PUSH_TO_TALK_KEY=space
# Note: on some Raspberry Pi setups `default` may fail for USB microphones.
# If recording fails, run `arecord -L` and set an explicit device, e.g.:
# AUDIO_INPUT_DEVICE=plughw:CARD=UACDemoV10,DEV=0
AUDIO_INPUT_DEVICE=default
AUDIO_OUTPUT_DEVICE=default
# For development, defaults are under ./local/svkrishna/* if unset.
# For production installs, /opt/svkrishna/* is typical.
AUDIO_WORK_DIR=/opt/svkrishna/audio
AUDIO_RECORD_SECONDS=5
AUDIO_SAMPLE_RATE=16000
ENABLE_AUDIO_PLAYBACK_DEBUG=false
WHISPER_LANGUAGE=en
ENABLE_TTS=true
ENABLE_RAG=true
RAG_SOURCE_DIR=/opt/svkrishna/rag/inbox
RAG_STORE_PATH=/opt/svkrishna/rag/store.json
RAG_CHUNK_SIZE=120
RAG_CHUNK_OVERLAP=30
RAG_TOP_K=3
RAG_EXTRACTOR_PYTHON=python3
# pypdf: fastest, basic PDF text extraction
# docling: structure-aware extraction (headings/tables) if docling is installed
RAG_EXTRACTOR_MODE=pypdf
PIPER_BINARY_PATH=piper
PIPER_MODEL_PATH=/path/to/piper/voice/model.onnx
WHISPER_MODEL=tiny.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_HOST=127.0.0.1
WHISPER_PORT=9001

# Service endpoints
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:1b
WHISPER_ENDPOINT=http://127.0.0.1:9001
PIPER_ENDPOINT=http://127.0.0.1:9002

# Feature toggles
ENABLE_WHISPER_HTTP=true
ENABLE_PIPER_HTTP=false
OLLAMA_SYSTEM_PROMPT=You are a concise offline boat assistant for SV Krishna. Answer clearly and briefly.

# Waveshare ESP32-S3-Relay-6CH (MAIN_WIFI_STA demo) integration
# The demo exposes HTTP endpoints like:
#   GET /getData  -> JSON array (6 relay flags)
#   GET /Switch1..6, /AllOn, /AllOff
RELAY_CONTROL_ENABLED=false
RELAY_BASE_URL=http://192.168.1.50
RELAY_REQUIRE_CONFIRMATION=true
