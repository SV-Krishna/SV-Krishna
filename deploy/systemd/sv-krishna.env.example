# Copy to: /etc/sv-krishna/sv-krishna.env
NODE_ENV=production
LOG_LEVEL=info

# Services (local-only on the Pi recommended)
OLLAMA_ENDPOINT=http://127.0.0.1:11434
WHISPER_ENDPOINT=http://127.0.0.1:9001

# Relay control (optional)
RELAY_CONTROL_ENABLED=true
RELAY_BASE_URL=http://svk-relay-6ch-551b18.local
RELAY_REQUIRE_CONFIRMATION=true

# Runtime paths (make sure this user can write them)
AUDIO_WORK_DIR=/var/lib/svkrishna/audio
RAG_SOURCE_DIR=/var/lib/svkrishna/rag/inbox
RAG_STORE_PATH=/var/lib/svkrishna/rag/store.json
EMBEDDING_STORE_PATH=/var/lib/svkrishna/rag/embeddings.json

# Feature toggles
ENABLE_WHISPER_HTTP=true
ENABLE_PIPER_HTTP=false
ENABLE_RAG=true
ENABLE_TTS=false

